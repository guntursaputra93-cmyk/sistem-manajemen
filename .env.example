# Supabase Postgres — admin/migration connection (bypasses RLS, role: postgres)
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Supabase Postgres — app runtime connection (subject to RLS, role: app_user)
DATABASE_URL_APP=postgresql://app_user.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# NextAuth v5 secret — generate with: openssl rand -base64 32
AUTH_SECRET=

# Sentry DSN (public, safe to expose client-side)
NEXT_PUBLIC_SENTRY_DSN=https://<key>@<org>.ingest.<region>.sentry.io/<project-id>

# Supabase Storage — service_role bypasses RLS, server-side only, JANGAN expose ke client
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
